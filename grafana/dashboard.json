{
  "title": "Sapient — Application Observability",
  "tags": ["sapient", "otel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus datasource",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by route (req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (rate(http_server_duration_milliseconds_count[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 request latency by route (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (http_route, le) (rate(http_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM tokens / minute (prompt vs completion)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "bars", "fillOpacity": 60, "stacking": {"mode": "normal"}}}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind, model) (rate(llm_tokens_total[5m]) * 60)",
          "legendFormat": "{{model}} / {{kind}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "LLM call rate by model + outcome",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model, status) (rate(llm_calls_total[5m]))",
          "legendFormat": "{{model}} ({{status}})"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rate-limit rejections per bucket",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 60}}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (bucket) (rate(rate_limit_rejections_total[5m]))",
          "legendFormat": "{{bucket}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "5xx rate (last 5m)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.1}
          ]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[5m]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Tokens / minute (last 5m)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_tokens_total[5m]) * 60)"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Active rate-limit pressure (1m)",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.05},
            {"color": "red", "value": 0.5}
          ]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rate_limit_rejections_total[1m]))"
        }
      ]
    }
  ]
}
